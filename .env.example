# ── LLM backend (for /ask endpoint) ──────────────────────────────────────────
# Set LLM_BACKEND to "gemini" or "anthropic" (default: anthropic)

LLM_BACKEND=gemini          # or "anthropic"

# Gemini (free tier — get key at https://aistudio.google.com)
GEMINI_API_KEY=AIza...

# Anthropic (optional, only needed if LLM_BACKEND=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# ── Embedding backend ─────────────────────────────────────────────────────────
EMBEDDING_BACKEND=local     # "local" (sentence-transformers) or "openai"
OPENAI_API_KEY=sk-...       # only needed if EMBEDDING_BACKEND=openai
